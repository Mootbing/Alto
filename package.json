{
  "name": "alto-ascii",
  "version": "0.1.0",
  "description": "Styled ASCII fallbacks for broken images using their alt text.",
  "type": "module",
  "types": "./src/index.d.ts",
  "homepage": "https://mootbing.github.io/Alto/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mootbing/Alto.git"
  },
  "bugs": {
    "url": "https://github.com/Mootbing/Alto/issues"
  },
  "license": "MIT",
  "author": "",
  "sideEffects": [
    "./src/alto.css",
    "./src/tailwind.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./next": {
      "types": "./src/next.d.ts",
      "import": "./src/next.js"
    },
    "./react": {
      "types": "./src/react.d.ts",
      "import": "./src/react.js"
    },
    "./style.css": "./src/alto.css",
    "./tailwind.css": "./src/tailwind.css"
  },
  "files": [
    "agents",
    "examples",
    "index.html",
    "SKILL.md",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "demo": "node examples/server.mjs",
    "test": "node --test",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "alt",
    "ascii",
    "fallback",
    "image",
    "nextjs",
    "placeholder",
    "tailwind",
    "accessibility"
  ],
  "peerDependencies": {
    "next": ">=13.4.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
